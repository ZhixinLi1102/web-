@model ResumeGenerator.Models.ResumeModel

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>简历预览</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .resume-preview-container {
            background-color: white;
            padding: 40px;
            margin: 20px auto;
            max-width: 800px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            font-family: "Microsoft YaHei", sans-serif;
        }
        .header { text-align: center; margin-bottom: 20px; position: relative; }
        .photo-placeholder {
            width: 120px; height: 160px; border: 1px dashed #ccc; 
            margin: 0 auto 10px; display: flex; align-items: center; justify-content: center;
            background-color: #f0f0f0; overflow: hidden;
        }
        .photo-placeholder img { max-width: 100%; max-height: 100%; object-fit: cover; }
        h1 { font-size: 28px; margin-bottom: 5px; }
        .contact-info p { margin: 5px 0; font-size: 14px; color: #555; }
        .section-title { font-weight: bold; border-bottom: 2px solid #007bff; padding-bottom: 5px; margin-top: 20px; margin-bottom: 10px; color: #333; }
        
        /* 打印按钮区域 */
        .action-bar { position: fixed; top: 10px; right: 10px; z-index: 1000; }
    </style>
</head>
<body>

    <!-- 操作按钮 -->
    <div class="action-bar no-print">
        <a href="/Resume/Create" class="btn btn-secondary me-2">返回修改</a>
        <button onclick="window.print()" class="btn btn-primary me-2">打印简历</button>
        <a href="/Resume/DownloadPdf" class="btn btn-danger">下载 PDF</a>
    </div>

    <div class="container resume-preview-container">
        <div class="header">
            <!-- 照片展示区域 -->
            <div class="photo-placeholder mb-3">
                @if (!string.IsNullOrEmpty(Model.PhotoBase64))
                {
                    <img src="@Model.PhotoBase64" style="width:120px;height:160px;" alt="个人照片" />
                }
                else
                {
                    <span>暂无照片</span>
                }
            </div>
            
            <h1>@Model.FullName</h1>
            求职意向：<strong>@Model.JobIntention</strong>
            
            <div class="contact-info mt-3">
                邮箱：@Model.Email
                电话：@Model.Phone
            </div>
        </div>

        <hr>

        <!-- 教育背景 -->
        <div class="section-title">教育背景</div>
        <div>@Model.School - @Model.Major (@Model.EducationDuration)</div>

        <!-- 实习经历 -->
        <div class="section-title">实习经历</div>
        <div>
            @if (!string.IsNullOrEmpty(Model.Internships))
            {        
                @Html.Raw(Model.Internships.Replace("\r\n", "<br />").Replace("\n", "<br />"))
            }
        </div>

        <!-- 项目经历 -->
        <div class="section-title">项目经历</div>
        <div>
            @if (!string.IsNullOrEmpty(Model.Projects))
            {
                @Html.Raw(Model.Projects.Replace("\r\n", "<br />").Replace("\n", "<br />"))
            }
        </div>

        <!-- 校园经历 -->
        <div class="section-title">校园经历</div>
        <div>
            @if (!string.IsNullOrEmpty(Model.CampusExps))
            {
                @Html.Raw(Model.CampusExps.Replace("\r\n", "<br />").Replace("\n", "<br />"))
            }
        </div>

        <!-- 技能特长 -->
        <div class="section-title">专业特长</div>
        <div>@Model.Skills</div>
    </div>

</body>
</html>